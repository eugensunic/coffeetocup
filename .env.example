# CoffeeToCup Environment Variables
# Copy this to .env and fill in your actual values

# Application
NODE_ENV=development
MAIL=info@coffeetocup.com
GENERATED_PASSWORD=your_password_here

# Google OAuth
# Get from: https://console.cloud.google.com/
# Create OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth
# Get from: https://developers.facebook.com/
# Create Facebook App and get App ID and Secret
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Database
# For development: Use MongoDB Atlas or local MongoDB
# For production: Use MongoDB Atlas production cluster
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true
